{
  "name": "@phpolygon/shader-gen-playground",
  "version": "0.0.0",
  "private": true,
  "description": "Browser playground for previewing and exporting shader effects",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/three": "^0.171.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
